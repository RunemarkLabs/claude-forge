# RuneSmith marketplace .gitignore
# This is the PUBLIC repo. Ships: plugins/, scripts/, .claude-plugin/,
# .github/, top-level docs (README, CHANGELOG, etc.), LICENSE, NOTICE,
# .credentials.example.

# --- Local secrets — never commit ---
.credentials
.credentials.local
*.pem
*.key

# --- Build output (regeneratable; not committed) ---
# Run `python scripts/build.py` or `bash scripts/build.sh` to produce
# .plugin files in ./dist/. Drag those into Cowork's plugin sidebar for
# manual install, or use `/plugin marketplace add runemarklabs/runesmith`
# for the git-based install path.
dist/

# --- OS junk ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- Editor / IDE ---
.vscode/
.idea/
*.iml

# --- Python ---
__pycache__/
*.pyc
*.pyo
