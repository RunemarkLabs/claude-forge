# =================================================================
# RuneSmith .gitignore
# =================================================================
# Items below this header are dev-environment artifacts. The public
# marketplace repo should ship: plugins/, dist/, .claude-plugin/,
# README.md, INSTALL.md, CHANGELOG.md, CONTRIBUTING.md, LICENSE,
# NOTICE, .credentials.example, .gitignore.

# --- Local secrets — never commit ---
.credentials
.credentials.local
*.pem
*.key

# --- Workspace dev environment (not part of the marketplace) ---
# CC monorepo heads — per runesmith convention, named <project>.cc/
*.cc/
# Legacy persistent clones (pre-runesmith era, may still linger)
.cowork-bootstrap/
.claude-code-bootstrap/
# Atlassian-enabled marker
.atlassian-enabled

# --- Personal authoring artifacts ---
notes/
drafts/
research/
source-docs/
tickets/
_INBOX/
plans/active/
plans/archive/
archive/
atlassian-index.json
HANDOFF*.md
bootstrap-setup-templates.md
claude-code-bootstrap-prompt.md

# --- Temporary / scratch ---
temp-clone/
_plugins_build/
plugins-v2/

# --- Old packaged plugins (pre-runesmith) ---
/bootstrap-core*.plugin
/atlassian-workflow.plugin
/workspace-tools.plugin
/bcore-*.plugin
/core.plugin
/atlassian.plugin
/aiops.plugin
/devtools.plugin
/dist-v2/

# --- Screenshots and binary attachments at repo root ---
/Screenshot*
*.png
!plugins/**/*.png

# --- OS junk ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- Editor / IDE ---
.vscode/
.idea/
*.iml
