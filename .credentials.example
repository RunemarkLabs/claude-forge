# GitHub credentials for repos in claude-code/
# Copy this file to .credentials and fill in your values
# DO NOT commit .credentials — it is gitignored

# Primary remote (source of truth — fetch + push)
PRIMARY_PAT=your_github_pat_here
PRIMARY_ORG=YourOrgName

# Mirror remote (push only) — omit section if not mirroring
# MIRROR_ORG=YourMirrorOrgName
# MIRROR_PAT_<repo-name>=your_mirror_pat_here
